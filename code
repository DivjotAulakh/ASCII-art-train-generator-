#include <stdio.h>
#include <stdlib.h>
#include <time.h>


int getNumCars(void);
char getDirection(void);
void drawTrain(int cars, char dir);
void printCarLine(int line, int windows);
void printSmokeLine(int cars, char dir, int carWidth, int gap, int engineWidth, int couplerWidth);

int getNumCars(void)
{
    int cars;
    int valid;

    cars = -1;
    valid = 0;

    while (!valid)
    {
        printf("Enter number of train cars (0-5): ");
        if (scanf("%d", &cars) != 1)
        {
            int ch;

            printf("Error: Please enter an integer from 0 to 5.\n");
            ch = 0;
            while ((ch = getchar()) != '\n' && ch != EOF)
            {
            }
        }
        else if (cars < 0 || cars > 5)
        {
            printf("Error: Number of cars must be between 0 and 5.\n");
        }
        else
        {
            valid = 1;
        }
    }

    return cars;
}

char getDirection(void)
{
    char dir;
    int valid;

    dir = '\0';
    valid = 0;

    while (!valid)
    {
        printf("Enter direction (L or R): ");
        scanf(" %c", &dir);

        if (dir >= 'a' && dir <= 'z')
        {
            dir = (char)(dir - 'a' + 'A');
        }

        if (dir == 'L' || dir == 'R')
        {
            valid = 1;
        }
        else
        {
            printf("Error: Direction must be L or R.\n");
        }
    }

    return dir;
}

void printCarLine(int line, int windows)
{
    int slot;

    slot = 0;

    if (line == 0)
    {
        printf("__________");
    }
    else if (line == 1)
    {
        putchar('|');

        for (slot = 0; slot < 4; slot++)
        {
            if (slot < windows)
            {
                putchar('o');
            }
            else
            {
                putchar(' ');
            }

            if (slot < 3)
            {
                putchar(' ');
            }
        }

        putchar(' ');
        putchar('|');
    }
    else if (line == 2)
    {
        printf("|________|");
    }
    else
    {
        printf(" @ @ @ @ ");
    }
}

void printSmokeLine(int cars, char dir, int carWidth, int gap, int engineWidth, int couplerWidth)
{
    int totalLen;
    int smokeLen;
    int engineStart;
    int chimneyPos;
    int start;
    int end;
    int col;

    if (cars > 0)
    {
        totalLen = (cars * carWidth) + ((cars - 1) * gap) + couplerWidth + engineWidth;
    }
    else
    {
        totalLen = engineWidth;
    }

    smokeLen = 3 + (cars * 2);

    if (dir == 'R')
    {
        if (cars > 0)
        {
            engineStart = (cars * carWidth) + ((cars - 1) * gap) + couplerWidth;
        }
        else
        {
            engineStart = 0;
        }
    }
    else
    {
        engineStart = 0;
    }

    chimneyPos = engineStart + 1;

    if (dir == 'R')
    {
        start = chimneyPos - smokeLen + 1;
        end = chimneyPos;
    }
    else
    {
        start = chimneyPos;
        end = chimneyPos + smokeLen - 1;
    }

    if (start < 0)
    {
        start = 0;
    }

    if (end >= totalLen)
    {
        end = totalLen - 1;
    }

    for (col = 0; col < totalLen; col++)
    {
        if (col >= start && col <= end)
        {
            putchar('~');
        }
        else
        {
            putchar(' ');
        }
    }
    putchar('\n');
}

void drawTrain(int cars, char dir)
{
    const char* engineR[4] = {
        "____",
        "|DD|____T_",
        "|_ |_____|<",
        " @-@-@-oo\\"
    };

    const char* engineL[4] = {
        "       ____",
        " _T____|DD|",
        ">|_____| _|",
        " /oo-@-@-@"
    };

    const int H = 4;
    const int CAR_WIDTH = 10;
    const int GAP = 2;
    const int COUPLER_WIDTH = 3;
    const int ENGINE_WIDTH = 10;

    int line;
    int i;
    int windows[5];

    line = 0;
    i = 0;

    for (i = 0; i < cars; i++)
    {
        windows[i] = rand() % 5;
    }

    printSmokeLine(cars, dir, CAR_WIDTH, GAP, ENGINE_WIDTH, (cars > 0) ? COUPLER_WIDTH : 0);

    for (line = 0; line < H; line++)
    {
        if (dir == 'R')
        {
            for (i = 0; i < cars; i++)
            {
                printCarLine(line, windows[i]);
                if (i < cars - 1)
                {
                    printf("%*s", GAP, "");
                }
            }

            if (cars > 0)
            {
                if (line == 1 || line == 2)
                {
                    printf("-*-");
                }
                else
                {
                    printf("   ");
                }
            }
            else
            {
                printf(" ");
            }

            printf("%s\n", engineR[line]);
        }
        else
        {
            printf("%s", engineL[line]);

            if (cars > 0)
            {
                if (line == 1 || line == 2)
                {
                    printf("-*-");
                }
                else
                {
                    printf("   ");
                }

                for (i = 0; i < cars; i++)
                {
                    printCarLine(line, windows[i]);
                    if (i < cars - 1)
                    {
                        printf("%*s", GAP, "");
                    }
                }
            }

            printf("\n");
        }
    }
}

int main(void)
{
    int cars;
    char dir;

    cars = 0;
    dir = 'R';

    srand((unsigned)time(NULL));

    cars = getNumCars();
    dir = getDirection();

    drawTrain(cars, dir);

    return 0;
}
